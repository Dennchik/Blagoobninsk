.section-greed._container 
	.section-greed__body 
		.mask-render
		.bg-grad 
		.section-greed__content 
			.section-greed__column
				nav.section-greed__menu 
					ul.section-greed__list 
						li.section-greed__item 
							a(href=linkTo('church/church', filename) title="Церковь").section-greed__link.link_underline Церковь 
						ul.section-greed__sub-menu 
							li.section-greed__sub-item 
								a(href=linkTo('church/church-history', filename) title="Церковь в истории").section-greed__link.link_underline  Церковь в истории 
							li.section-greed__sub-item 
								span.section-greed__link.link-hover Епархиальная и приходская жизнь
							li.section-greed__sub-item 
								a(href=linkTo('church/social', filename) title="Социальное служение").section-greed__link.link_underline Социальное служение 
							li.section-greed__sub-item 
								a(href=linkTo('church/catechism', filename) title="Образование и катехизис").section-greed__link.link_underline Образование и катехизис 
							li.section-greed__sub-item 
								a(href=linkTo('church/monashestvo', filename) title="Монашество").section-greed__link.link_underline  Монашество 
			.section-greed__column 
				.section-greed__bread-crumbs
					nav.bread-crumbs
						ul.bread-crumbs__list
							li
								a(href=getWebRoot(filename) + "index.html" aria-label="home" title="Главная").bread-crumbs__link.link_underline Главная 
							li.bread-crumbs__item  
								+iconfont('angle-right', '_icon')
							li  
								a(href=linkTo('church/church', filename) title="Церковь").bread-crumbs__link.link_underline Церковь 
							li.bread-crumbs__item  
								+iconfont('angle-right', '_icon')
							li
								span.bread-crumbs__item Епархиальная и приходская жизнь
				.section-greed__title 
					hgroup.title.tl-02 
						h1 
							span Епархиальная и приходская жизнь
					.hr 
						+picture('/img/frame/hr.png', 'image') 
				.section-greed__row
					.info-content 
						.info-content__column 
							.info-content__row