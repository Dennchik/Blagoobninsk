.section-greed._container
	.section-greed__body
		.mask-render
		.bg-grad
		.section-greed__content
			.section-greed__column
				aside.aside-menu(data-da="bp-1" data-da-position="1" data-da-resolution="690")
					ul.aside-menu__list 
						li.aside-menu__item 
							span.aside-menu__link.link-hover О&nbsp;благочинии
						ul.aside-menu__sub-menu
							li.aside-menu__item 
								a(href=linkTo('blagochinie/temples', filename) title="Храмы благочиния").aside-menu__link 
									span Храмы благочиния 
							li.aside-menu__item 
								a(href=linkTo('blagochinie/duhovenstvo', filename) title="Духовенство").aside-menu__link 
									span Духовенство 
						li.aside-menu__item 
							a(href=linkTo('blagochinie/patriarh', filename) title="Патриарх").aside-menu__link 
								span Патриарх 
						li.aside-menu__item 
							a(href=linkTo('blagochinie/arhierey', filename) title="Правящий архиерей").aside-menu__link 
								span Правящий архиерей 
			.section-greed__column
				.section-greed__bread-crumbs
					nav.bread-crumbs
						ul.bread-crumbs__list
							li.bread-crumbs__item
								a(href=getWebRoot(filename) + "index.html" aria-label="home" title="Главная").bread-crumbs__link.link_underline Главная 
							li.bread-crumbs__item
								+iconfont('angle-right', '_icon')
							li.bread-crumbs__item
								span О благочинии
				hgroup.title.tl-02.section-greed__title
					h2
						span О благочинии
					.hr
						+picture('/img/frame/hr.png', 'image') 
				.section-greed__row
					.info-content
						.info-content__column
							.gallery
								.gallery__top
									.gallery-item.gallery__card
										.gallery-item__image._img
											+picture('/img/photo/sergiy-vishnyakov.png', 'image') 
										.gallery-item__info
											.gallery-item__post
												p Благочинный Протоиерей 
												span 3-его благочиния г. Обнинска 
											.gallery-item__name.t-019
												strong Сергий Вишняков 
											.gallery-item__text Настоятель храма в честь мучениц Веры, Надежды, Любови и матери их Софии
							.info-content__row
								.info-content__title.t-019
									p В благочинии 3-го округа состоят десять приходов, на&nbsp;которых несут послушание 18&nbsp;священнослужителей (15&nbsp;священников и&nbsp;2&nbsp;дьякона)(один&nbsp;священник за&nbsp;штатом):
								.info-content__text
									ul.info-content__list
										li.info-content__item
											a(href='http://hramrh.ru/' target='_blank').link_underline Приход храма Рождества Христова г. Обнинск 
										li.info-content__item
											a(href='http://belkino.su' target='_blank').link_underline Приход храма Св. Бориса и Глеба пос. Белкино
										li.info-content__item
											a(href='https://vera-obninsk.ru/' target='_blank').link_underline Приход ДПЦ «Вера, Надежда, Любовь» г. Обнинск
										li.info-content__item
											a(href='http://shram-st.ru/' target='_blank').link_underline Приход храма Свт. Тихона г. Обнинск 
										li.info-content__item 
											a(href='http://hramsvtluki.ru' target='_blank').link_underline Настоятель Храма в честь святителя Луки
											a(href='#' target='_blank').link_underline Молитвенный дом в честь св. равн. вел. кн. Владимира и вел. кн. Ольги
										li.info-content__item
											a(href='http://www.hrampg.ru/' target='_blank').link_underline Приход храма Преображения Господня с. Спас-Загорье
										li.info-content__item
											a(href='' target='_blank').link_underline Приход храма Св. вмч. Пантелимона г. Обнинск
										li.info-content__item 
											a(href='http://www.mirspas.ru/' target='_blank').link_underline  Храм в честь Спаса Нерукотворного (при казачьей общине «Спас»)
										li.info-content__item 
											a(href="#") Храм благоверных Петра и Февронии Муромских