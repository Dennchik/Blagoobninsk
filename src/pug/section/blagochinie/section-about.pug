.section-greed._container
	.section-greed__body
		.mask-render
		.bg-grad
		.section-greed__content
			.section-greed__column
				nav.section-greed__menu
					ul.section-greed__list
						li.section-greed__item
							span.section-greed__link.link-hover О&nbsp;благочинии
						ul.section-greed__sub-menu
							li.section-greed__sub-item
								a(href=linkTo('blagochinie/temples', filename) title="Храмы благочиния ").section-greed__link.link_underline Храмы благочиния 
							li.section-greed__sub-item
								a(href=linkTo('blagochinie/duhovenstvo', filename) title="Духовенство").section-greed__link.link_underline Духовенство 
						li.section-greed__item
							a(href=linkTo('blagochinie/patriarh', filename) title="Патриарх").section-greed__link.link_underline Патриарх 
						li.section-greed__item
							a(href=linkTo('blagochinie/arhierey', filename) title="Правящий архиерей").section-greed__link.link_underline Правящий архиерей 
			.section-greed__column
				.section-greed__bread-crumbs
					nav.bread-crumbs
						ul.bread-crumbs__list
							li.bread-crumbs__item
								a(href=getWebRoot(filename) + "index.html" aria-label="home" title="Главная").bread-crumbs__link.link_underline Главная 
							li.bread-crumbs__item
								+iconfont('angle-right', '_icon')
							li.bread-crumbs__item
								span О благочинии
				hgroup.title.tl-02.section-greed__title
					h2
						span О благочинии
					.hr
						+picture('/img/frame/hr.png', 'image') 
				.section-greed__row
					.info-content
						.info-content__column
							.gallery
								.gallery__top
									.gallery-item.gallery__card
										.gallery-item__image._img
											+picture('/img/photo/sergiy-vishnyakov.png', 'image') 
										.gallery-item__info
											.gallery-item__post
												p Благочинный Протоиерей 
												span 3-его благочиния г. Обнинска 
											.gallery-item__name.t-019
												strong Сергий Вишняков 
											.gallery-item__text Настоятель храма в честь мучениц Веры, Надежды, Любови и матери их Софии
											a(href="#").gallery-item__link.link_underline
												span Подробнее
							.info-content__row
								.info-content__title.t-019
									p В благочинии 3-го округа состоят десять приходов, на&nbsp;которых несут послушание 18&nbsp;священнослужителей (15&nbsp;священников и&nbsp;2&nbsp;дьякона)(один&nbsp;священник за&nbsp;штатом):
								.info-content__text
									ul.info-content__list
										li.info-content__item
											a(href=linkTo('blagochinie/temples#1', filename)).link_underline.anchor-link Приход храма Рождества Христова г. Обнинск 
										li.info-content__item
											a(href=linkTo('blagochinie/temples#tl-02', filename)).link_underline.anchor-link Приход храма Св. равноап. Владимира и Ольги г. Обнинск 
										li.info-content__item Приход храма Св. Бориса и Глеба пос. Белкино
										li.info-content__item Приход храма Свт. Тихона г. Обнинск
										li.info-content__item Приход храма Св. вмч. Пантелимона г. Обнинск
										li.info-content__item Приход храма Преображения Господня с. Спас-Загорье
										li.info-content__item Приход ДПЦ «Вера, Надежда, Любовь» г. Обнинск
										li.info-content__item Приход храма в честь святителя Луки, архиепископа Симферопольского и Крымского при Медицинском радиологическом научном центре г. Обнинск
										li.info-content__item Приход храма Рождества Христова г. Обнинск