include @/pug/includes/mixins
doctype html
html(lang="ru")
	head
		meta(charset="UTF-8")
		meta(http-equiv="X-UA-Compatible" content="IE=edge")
		meta(name="mobile-web-app-capable" content="yes")
		meta(name="apple-mobile-web-app-capable" content="yes")
		meta(name="viewport" content="width=device-width, initial-scale=1.0")
		meta(name="description" content="Краткое описание документа")
		meta(name="keywords" content="keywords-ключевые слова для поиска")
		block link 
			link(rel="icon" type="image/icon" href="/img/icons/logo.png") 
		block style
		block script 
			script(defer type="module" src="/src/js/app.js")
			script(defer type="module" src="/src/js/main.js")

		block title
		- var text
			title #{text}

	body
		include @/pug/utils/preloader
		include @/pug/includes/mixins
		.wrapper
			.page
				block header 
					header.page__header
						include @/pug/layouts/header
				block mask-render
				block page-content
					main.page__main-content
						.main-content#wrapper
							.main-content__content#content
								block main-content 
								block main-content-items
								footer.main-content__footer
									block footer 
										include footer 
					block menu-list
						nav.page__menu-list
							include @/pug/chunks/menu-list
					block aside-button
						.return-button#scrollButton
							._arrow._button
								img(src="/img/frame/arrow.png" alt="image")
							//- +iconfont('angle-down', '_button')
							//- block content-hidden
							//- block burger-menu
							//- 	include ../assets/burger-menu
							//- include ../layouts/page-grid